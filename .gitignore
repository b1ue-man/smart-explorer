# Rust build output (huge, regenerable)
native/target/
native/explorer-command/target/

# Built binaries & generated installer artifacts
*.exe
release-native/Smart Explorer*.exe

# OS / editor cruft
Thumbs.db
.DS_Store
*.swp

# EXCEPTION: the git update feed IS committed — it is the update location.
# Installs pull release-native/update-feed/{version.txt,smart_explorer.exe,...}
# over raw.githubusercontent.com. (Negation must come after the *.exe rule.)
!release-native/update-feed/
!release-native/update-feed/version.txt
!release-native/update-feed/smart_explorer.exe
!release-native/update-feed/smart_explorer.exe.sha256
!release-native/update-feed/smart_explorer_updater.exe
!release-native/update-feed/smart_explorer_updater.exe.sha256
# EXCEPTION: ship the installer + portable exe so they're downloadable from the
# repo (and referenced by the README). The Release attaches them too.
!release-native/Smart Explorer Setup *.exe
!release-native/Smart Explorer.exe
!release-native/Smart Explorer Updater.exe
!release-native/share-server/
!release-native/share-server/se-share-server.exe

# Standalone se-agent crate build artifacts (the built binaries are committed
# under native/agent-bin/, not these).
/se-agent/target/
