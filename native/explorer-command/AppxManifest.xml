<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparse-package manifest that wires the IExplorerCommand handler
  (smart_explorer_command.dll, CLSID below) into the Windows 11 MODERN context
  menu. A "sparse" package carries identity + the handler but leaves the app
  unpackaged (per-user install under %LOCALAPPDATA%\Programs\Smart Explorer).

  HARD REQUIREMENT: this package MUST be signed with a certificate the machine
  trusts, and Publisher below MUST equal the cert subject EXACTLY. See
  docs/WIN11_CONTEXT_MENU.md. Without trusted signing, Windows refuses to
  register the package — this is the wall.

  Placeholders to fill before packaging:
    * Publisher           — CN of your signing cert (e.g. "CN=Your Name")
    * uap10:Executable    — path to the installed Smart Explorer.exe
    * Version             — keep in step with the app version
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  IgnorableNamespaces="uap uap10 rescap com desktop4 desktop5">

  <Identity Name="SmartExplorer.ContextMenu"
            Publisher="CN=REPLACE_WITH_CERT_SUBJECT"
            Version="0.5.2.0"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Smart Explorer</DisplayName>
    <PublisherDisplayName>Silas</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.22000.0"
                        MaxVersionTested="10.0.22631.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

  <Applications>
    <Application Id="SmartExplorer"
                 uap10:TrustLevel="mediumIL"
                 uap10:RuntimeBehavior="packagedClassicApp"
                 uap10:Executable="%LOCALAPPDATA%\Programs\Smart Explorer\Smart Explorer.exe"
                 EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements DisplayName="Smart Explorer" Description="Fast native file explorer"
                          BackgroundColor="transparent"
                          Square150x150Logo="Assets\Square150x150Logo.png"
                          Square44x44Logo="Assets\Square44x44Logo.png" />

      <Extensions>
        <!-- The in-proc COM server: CLSID -> the handler DLL in the package. -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:InProcServer>
              <com:Class Id="7F3B1E20-9C4A-4D8E-A1B2-3C4D5E6F7081"
                         ThreadingModel="STA"
                         Path="smart_explorer_command.dll" />
            </com:InProcServer>
          </com:ComServer>
        </com:Extension>

        <!-- Surface the verb on folders, the folder background, and drives. -->
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type="Directory">
              <desktop5:Verb Id="OpenInSmartExplorer"
                             Clsid="7F3B1E20-9C4A-4D8E-A1B2-3C4D5E6F7081" />
            </desktop5:ItemType>
            <desktop5:ItemType Type="Directory\Background">
              <desktop5:Verb Id="OpenInSmartExplorer"
                             Clsid="7F3B1E20-9C4A-4D8E-A1B2-3C4D5E6F7081" />
            </desktop5:ItemType>
            <desktop5:ItemType Type="Drive">
              <desktop5:Verb Id="OpenInSmartExplorer"
                             Clsid="7F3B1E20-9C4A-4D8E-A1B2-3C4D5E6F7081" />
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>
      </Extensions>
    </Application>
  </Applications>
</Package>
